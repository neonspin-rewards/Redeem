{
  /*
  ═══════════════════════════════════════════════════════════════
  NEONSPIN — Firebase Realtime Database Security Rules
  Project : neonspin-rewards-4101a
  DB URL  : https://neonspin-rewards-4101a-default-rtdb.firebaseio.com

  HOW TO DEPLOY:
  Option A — Firebase Console (easiest):
    1. Go to https://console.firebase.google.com
    2. Select project "neonspin-rewards-4101a"
    3. Realtime Database → Rules tab
    4. Paste the "rules" object below (without the outer comments)
    5. Click Publish

  Option B — Firebase CLI:
    firebase deploy --only database

  STRUCTURE THESE RULES PROTECT:
    /users/{uid}/          — player profile & stats
    /feedback/{pushId}/    — community feedback posts
    /rewardRequests/{id}/  — reward claim requests

  SECURITY PHILOSOPHY:
    1. No public read/write — auth required for everything
    2. Users can only write their OWN profile (uid must match)
    3. Users can read ALL profiles (needed for leaderboard)
    4. Feedback is readable by all signed-in users
    5. Reward requests: users write their own, admins manage them
    6. Server-side validation prevents impossible stat values
    7. Rate-limit fields (spinCount, coins) have max value checks
  ═══════════════════════════════════════════════════════════════
  */

  "rules": {

    /* ── /users ─────────────────────────────────────────────────
       Stores every player's profile, stats, and progress.

       Read:  Any authenticated user can read any profile.
              Required for the leaderboard to display all players.

       Write: A user can ONLY write to their OWN node (uid match).
              This prevents Player A from editing Player B's coins.

       Validation rules prevent:
         - Negative coins or EXP
         - Impossible level values (< 1)
         - Streak values > 3650 (10 years)
         - spinCount going backwards
         - Writing unknown/extra fields (allowUnknown: false implied)
    ─────────────────────────────────────────────────────────────  */
    "users": {

      /* Leaderboard: any signed-in user can list all players */
      ".read": "auth !== null",

      "$uid": {

        /* Each user can only write to their OWN profile node */
        ".write": "auth !== null && auth.uid === $uid",

        /* ── Field-level validation ──────────────────────────── */
        "coins": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        },
        "exp": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000000"
        },
        "level": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 1000"
        },
        "streak": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3650"
        },
        "spinCount": {
          /* spinCount can only increase — prevents rewind exploits */
          ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || newData.val() >= data.val())"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 60"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "photoURL": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "referralCode": {
          ".validate": "newData.isString() && newData.val().length <= 8"
        },
        "referredBy": {
          ".validate": "newData.isString() && newData.val().length <= 8"
        },
        "lastLoginDay": {
          /* Must be a date string like "2025-04-01" (10 chars) */
          ".validate": "newData.isString() && newData.val().length === 10"
        },
        "lastDailyReward": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "joinedAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "uid": {
          /* uid stored in profile must match the auth uid — no spoofing */
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "milestonesAchieved": {
          ".validate": "newData.isString() || newData.hasChildren()",
          "$milestoneIndex": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          }
        }
      }
    },

    /* ── /feedback ──────────────────────────────────────────────
       Community feedback posts with optional Cloudinary images.

       Read:  Any signed-in user can read feedback (for the feed).
       Write: Any signed-in user can submit feedback.
              Each post is tied to the submitter's uid.
              Validation prevents spam or empty submissions.
    ─────────────────────────────────────────────────────────────  */
    "feedback": {

      ".read":  "auth !== null",

      "$feedbackId": {

        /* Any authenticated user can push a new feedback post */
        ".write": "auth !== null",

        "userId": {
          /* Must match the submitter — prevents posting as someone else */
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 60"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "message": {
          /* Max 300 chars matches the HTML textarea maxlength */
          ".validate": "newData.isString() && newData.val().length <= 300"
        },
        "imageURL": {
          /* Cloudinary URL or empty string — max 500 chars */
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "timestamp": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        }
      }
    },

    /* ── /rewardRequests ────────────────────────────────────────
       Reward claim requests submitted by eligible players.
       Admins review and update status via Firebase Console.

       Read:  Only the user who submitted can read their own request.
              (They don't need to see other users' requests.)
       Write: Users can create new requests (status must be "pending").
              Users CANNOT update status — only admins can via Console.
    ─────────────────────────────────────────────────────────────  */
    "rewardRequests": {

      "$requestId": {

        /* Only the requesting user can read their own request */
        ".read": "auth !== null && data.child('uid').val() === auth.uid",

        /* Users can only CREATE new requests — not update existing ones.
           An update would require !data.exists() to be false,
           meaning the record already exists, which we block here.
           Admins update via Firebase Console with admin SDK.         */
        ".write": "auth !== null && !data.exists()",

        "uid": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 60"
        },
        "level": {
          /* Must be at least 10 to be eligible */
          ".validate": "newData.isNumber() && newData.val() >= 10"
        },
        "coins": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "streak": {
          /* Must be at least 7 to be eligible */
          ".validate": "newData.isNumber() && newData.val() >= 7"
        },
        "status": {
          /* New requests must always start as "pending" */
          ".validate": "newData.isString() && newData.val() === 'pending'"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        }
      }
    },

    /* ── Default deny ────────────────────────────────────────────
       Any path not explicitly listed above is blocked entirely.
       This is the "deny by default" safety net.
    ─────────────────────────────────────────────────────────────  */
    "$other": {
      ".read":  false,
      ".write": false
    }

  }
}
